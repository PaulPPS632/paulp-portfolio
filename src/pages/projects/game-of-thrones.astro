---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Arya from "../../assets/game-of-thrones/arya-stark.webp";
import HomeGOT from "../../assets/game-of-thrones/screens-project/home-got.webp";
import CapitulosGOT from "../../assets/game-of-thrones/screens-project/capitulos-got.webp";
import CapituloGOT from "../../assets/game-of-thrones/screens-project/capitulo-got.webp";
import BooksGOT from "../../assets/game-of-thrones/screens-project/books-got.webp";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout backgroundColor="#111212">
    <Header />
    <main class="got-story-page relative mx-auto flex w-full max-w-6xl flex-col gap-14 px-4 pb-20 pt-28 sm:px-8 sm:pt-32">
        <section data-animate="hero" class="relative overflow-hidden rounded-3xl border border-[#2a2a2a] bg-[#161718] p-6 shadow-[0_20px_60px_rgba(0,0,0,0.35)] sm:p-10">
            <p class="mb-3 inline-block rounded-full border border-[#3a3a3a] bg-[#1d1f20] px-3 py-1 font-sans text-xs font-semibold uppercase tracking-[0.18em] text-[#9ca3af]">
                Proyecto de inicios
            </p>
            <h1 class="max-w-3xl font-sans text-[clamp(2rem,4vw,3.5rem)] font-black leading-[1.05] text-[#f5f5f5]">
                Game of Thrones Hub
            </h1>
            <p class="mt-4 max-w-3xl font-sans text-base leading-relaxed text-[#c7c9ce] sm:text-lg">
                Este fue uno de mis primeros proyectos reales como desarrollador. Como fan de la saga,
                decidí construir una web para consultar capítulos en video y explorar los libros en un
                solo lugar, priorizando simplicidad y una experiencia clara.
            </p>

            <div class="mt-7 grid gap-3 sm:grid-cols-3">
                <div class="js-stat rounded-xl border border-[#2f3133] bg-[#1b1d1f] p-4">
                    <p class="font-sans text-xs uppercase tracking-widest text-[#9ca3af]">Framework</p>
                    <p class="mt-1 font-sans text-lg font-bold text-[#f5f5f5]">Angular</p>
                </div>
                <div class="js-stat rounded-xl border border-[#2f3133] bg-[#1b1d1f] p-4">
                    <p class="font-sans text-xs uppercase tracking-widest text-[#9ca3af]">UI</p>
                    <p class="mt-1 font-sans text-lg font-bold text-[#f5f5f5]">TailwindCSS</p>
                </div>
                <div class="js-stat rounded-xl border border-[#2f3133] bg-[#1b1d1f] p-4">
                    <p class="font-sans text-xs uppercase tracking-widest text-[#9ca3af]">Datos/Videos</p>
                    <p class="mt-1 font-sans text-lg font-bold text-[#f5f5f5]">Google Drive (sin backend)</p>
                </div>
            </div>
        </section>

        <section class="js-story-grid grid gap-5 sm:grid-cols-3">
            <article class="js-story-card rounded-2xl border border-[#2a2a2a] bg-[#18191b] p-6">
                <h2 class="font-sans text-lg font-black text-[#f5f5f5]">Contexto</h2>
                <p class="mt-3 font-sans text-sm leading-relaxed text-[#c7c9ce]">
                    En esa etapa quería practicar estructura de componentes y navegación en Angular con un
                    tema que ya conocía bien. Game of Thrones fue ideal para mantener motivación y foco.
                </p>
            </article>

            <article class="js-story-card rounded-2xl border border-[#2a2a2a] bg-[#18191b] p-6">
                <h2 class="font-sans text-lg font-black text-[#f5f5f5]">El porqué</h2>
                <p class="mt-3 font-sans text-sm leading-relaxed text-[#c7c9ce]">
                    Quería una plataforma rápida donde pudiera encontrar capítulos y libros sin fricción.
                    El objetivo era unir contenido audiovisual y lectura en una interfaz directa.
                </p>
            </article>

            <article class="js-story-card rounded-2xl border border-[#2a2a2a] bg-[#18191b] p-6">
                <h2 class="font-sans text-lg font-black text-[#f5f5f5]">Datos de desarrollo</h2>
                <ul class="mt-3 space-y-2 font-sans text-sm text-[#c7c9ce]">
                    <li>• SPA en Angular.</li>
                    <li>• Estilos 100% con TailwindCSS.</li>
                    <li>• Sin backend propio.</li>
                    <li>• Videos embebidos y organizados desde Drive.</li>
                </ul>
            </article>
        </section>

        <section class="space-y-4">
            <h2 class="font-sans text-2xl font-black text-[#f5f5f5]">Pantallas del proyecto</h2>
            <div class="js-gallery-grid grid gap-4 md:grid-cols-2">
                <figure class="js-shot overflow-hidden rounded-2xl border border-[#2a2a2a] bg-[#171819]">
                    <img src={HomeGOT.src} alt="Pantalla principal del proyecto Game of Thrones" class="h-full w-full object-cover" />
                    <figcaption class="border-t border-[#2a2a2a] px-4 py-3 font-sans text-sm text-[#c7c9ce]">Inicio con acceso principal al contenido.</figcaption>
                </figure>

                <figure class="js-shot overflow-hidden rounded-2xl border border-[#2a2a2a] bg-[#171819]">
                    <img src={CapitulosGOT.src} alt="Listado de capítulos en la web de Game of Thrones" class="h-full w-full object-cover" />
                    <figcaption class="border-t border-[#2a2a2a] px-4 py-3 font-sans text-sm text-[#c7c9ce]">Vista de capítulos organizada por navegación simple.</figcaption>
                </figure>

                <figure class="js-shot overflow-hidden rounded-2xl border border-[#2a2a2a] bg-[#171819]">
                    <img src={CapituloGOT.src} alt="Pantalla de reproducción de un capítulo de Game of Thrones" class="h-full w-full object-cover" />
                    <figcaption class="border-t border-[#2a2a2a] px-4 py-3 font-sans text-sm text-[#c7c9ce]">Reproducción del capítulo usando recursos alojados en Drive.</figcaption>
                </figure>

                <figure class="js-shot overflow-hidden rounded-2xl border border-[#2a2a2a] bg-[#171819]">
                    <img src={BooksGOT.src} alt="Sección de libros de Game of Thrones" class="h-full w-full object-cover" />
                    <figcaption class="border-t border-[#2a2a2a] px-4 py-3 font-sans text-sm text-[#c7c9ce]">Sección de libros para complementar la experiencia.</figcaption>
                </figure>
            </div>
        </section>

        <img
            src={Arya.src}
            alt="Arya Stark from Game of Thrones"
            class="js-arya pointer-events-none fixed bottom-0 left-4 z-10 w-36 opacity-95 sm:left-10 sm:w-52"
            transition:name="arya-stark"
        />
    </main>
</Layout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    function initGOTPageAnimations() {
        const page = document.querySelector<HTMLElement>(".got-story-page");
        if (!page) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        gsap.registerPlugin(ScrollTrigger);

        gsap.from("[data-animate='hero']", {
            autoAlpha: 0,
            y: 32,
            duration: 0.85,
            ease: "power3.out",
        });

        gsap.from(".js-stat", {
            autoAlpha: 0,
            y: 20,
            duration: 0.55,
            delay: 0.2,
            stagger: 0.12,
            ease: "power2.out",
        });

        gsap.from(".js-story-card", {
            scrollTrigger: {
                trigger: ".js-story-grid",
                start: "top 78%",
                once: true,
            },
            autoAlpha: 0,
            y: 28,
            duration: 0.65,
            stagger: 0.14,
            ease: "power2.out",
        });

        gsap.from(".js-shot", {
            scrollTrigger: {
                trigger: ".js-gallery-grid",
                start: "top 80%",
                once: true,
            },
            autoAlpha: 0,
            y: 24,
            scale: 0.97,
            duration: 0.7,
            stagger: 0.12,
            ease: "power2.out",
        });

        gsap.to(".js-arya", {
            y: -14,
            duration: 2.2,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
        });
    }

    document.addEventListener("astro:page-load", initGOTPageAnimations);
</script>
