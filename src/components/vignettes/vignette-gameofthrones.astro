---
import Arya from "../../assets/game-of-thrones/arya-stark.webp";
---

<div class="relative w-full h-full">
    <div class="bg-white px-2">
        <h3 class="font-sans text-xl font-black leading-tight text-black">
            GOT
        </h3>
    </div>
    <p class="font-sans text-sm font-semibold leading-relaxed text-black/80">
        goli
    </p>
    <img
        src={Arya.src}
        alt="Arya Stark from Game of Thrones"
        class="absolute bottom-0 left-10 w-18"
        transition:name="arya-stark"
    />
</div>
