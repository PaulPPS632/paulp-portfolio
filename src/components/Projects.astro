	{
		title: 'Portfolio Motion',
		description: 'Landing personal con transiciones fluidas, storytelling visual y micro-animaciones.',
		tags: ['Astro', 'Tailwind', 'GSAP'],
		color: '#ff5b8f',
	},
	{
		title: 'Task Radar',
		description: 'Gestor de tareas con priorización inteligente y drag-and-drop semanal.',
		tags: ['React', 'TypeScript', 'DnD'],
		color: '#9be35a',
	},
	{
		title: 'Dev Notes API',
		description: 'API REST con autenticación JWT, rate limiting y docs automáticos.',
		tags: ['Node', 'Express', 'PostgreSQL'],
		color: '#71caff',
	},
	{
		title: 'Commerce UI Kit',
		description: 'Biblioteca de componentes accesibles para ecommerce con design tokens.',
		tags: ['Design System', 'Storybook', 'CSS'],
		color: '#ffd84d',
	},
	{
		title: 'FitMap Tracker',
