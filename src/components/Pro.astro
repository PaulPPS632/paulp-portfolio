---
import VignetteGameofthrones from "./vignettes/vignette-gameofthrones.astro";

const data = 2;
---

<section
    id="projects"
    class="flex min-h-screen scroll-mt-24 flex-col items-center px-4 py-20 sm:px-8"
>
    <div
        class="comic-page grid grid-cols-3 grid-rows-8 w-full max-w-6xl h-[80vh] rounded-lg border-[6px] border-black bg-black shadow-[8px_8px_0_#1a1a1a] gap-2"
    >
        <div class="vineta row-span-2 bg-[#111212] v-1 flex items-center justify-center cursor-pointer" data-url="/game-of-thrones">
            <VignetteGameofthrones />
        </div>
        <div class="vineta row-span-2 col-start-1 row-start-3 bg-amber-300 v-2 flex items-center justify-center cursor-pointer">2</div>
        <div class="vineta row-span-2 col-start-1 row-start-5 bg-green-400 v-3 flex items-center justify-center cursor-pointer">3</div>
        <div class="vineta row-span-2 col-start-1 row-start-7 bg-blue-400 v-4 flex items-center justify-center cursor-pointer">4</div>
        <div class="vineta row-span-5 col-start-2 row-start-1 bg-purple-400 v-5 flex items-center justify-center cursor-pointer">5</div>
        <div class="vineta row-span-3 col-start-2 row-start-6 bg-pink-400 v-6 flex items-center justify-center cursor-pointer">6</div>
        <div class="vineta row-span-2 col-start-3 row-start-1 bg-yellow-400 v-7 flex items-center justify-center cursor-pointer">7</div>
        <div class="vineta row-span-2 col-start-3 row-start-3 bg-indigo-400 v-8 flex items-center justify-center cursor-pointer">8</div>
        <div class="vineta row-span-2 col-start-3 row-start-5 bg-teal-400 v-9 flex items-center justify-center cursor-pointer">9</div>
        <div class="vineta row-span-2 col-start-3 row-start-7 bg-gray-400 v-10 flex items-center justify-center cursor-pointer">10</div>
    </div>
</section>
<style>
    .v-1 {
        clip-path: polygon(0 0, 92% 0, 98% 85%, 0% 100%);
        margin-bottom: -25px; /* Overlay intencional para romper la rigidez */
    }
    .v-2 {
        /* Forma de trapecio irregular */
        clip-path: polygon(0% 15%, 95% 0%, 100% 100%, 0% 100%);
        margin-right: -15px;
    }

    .v-3 {
        clip-path: polygon(0% 0%, 95% 0%, 100% 88%, 0% 100%);
        margin-right: -38px;
        margin-bottom: -20px;
    }

    .v-4 {
        clip-path: polygon(0% 12%, 95% 0%, 100% 100%, 0% 100%);
        margin-right: -61px;
    }
    .v-5 {
        clip-path: polygon(0% 0%, 90% 0%, 100% 90%, 14% 98%);
        margin-left: -30px;
    }
    .v-6 {
        clip-path: polygon(6.5% 12%, 88.5% 0%, 95% 100%, 14.5% 100%);
        margin-top: -44px;
        margin-right: -50px;
    }
    .v-7 {
        clip-path: polygon(0% 0%, 100% 0%, 100% 80%, 4.5% 100%);
        margin-left: -40px;
        margin-bottom: -30px;
    }
    .v-8 {
        clip-path: polygon(0% 22%, 100% 0%, 100% 100%, 3.5% 100%);
        margin-left: -19px;
        margin-top: -10px;
    }
    .v-9 {
        clip-path: polygon(0% 0%, 100% 0%, 100% 80%, 4.5% 100%);
        margin-bottom: -20px;
        margin-left: -4px;
    }
    .v-10 {
        clip-path: polygon(4% 22%, 100% 0%, 100% 100%, 7.5% 100%);
        margin-top: -19px;
    }
</style>

<script>
    import gsap from "gsap";
    import { navigate } from "astro:transitions/client";

    function initComicZoom() {
        const comicPage = document.querySelector<HTMLElement>(".comic-page");
        const vinetas = document.querySelectorAll<HTMLElement>(".vineta");
        if (!comicPage || !vinetas.length) return;

        let isZoomed = false;
        let isRedirecting = false;
        let currentTl: gsap.core.Timeline | null = null;

        function zoomToVineta(vineta: HTMLElement, targetUrl?: string) {
            if (isZoomed) return;

            const comicRect = comicPage!.getBoundingClientRect();
            const vinetaRect = vineta.getBoundingClientRect();

            // Centro de la viñeta relativo al comic-page (en %)
            const vinetaCenterX = vinetaRect.left + vinetaRect.width / 2 - comicRect.left;
            const vinetaCenterY = vinetaRect.top + vinetaRect.height / 2 - comicRect.top;
            const originX = (vinetaCenterX / comicRect.width) * 100;
            const originY = (vinetaCenterY / comicRect.height) * 100;

            // Escala para que la viñeta cubra más que la pantalla
            const scaleX = (window.innerWidth / vinetaRect.width) * 1.3;
            const scaleY = (window.innerHeight / vinetaRect.height) * 1.3;
            const scale = Math.max(scaleX, scaleY);

            // Traducción para centrar la viñeta en el viewport
            const viewportCenterX = window.innerWidth / 2;
            const viewportCenterY = window.innerHeight / 2;
            const currentCenterX = vinetaRect.left + vinetaRect.width / 2;
            const currentCenterY = vinetaRect.top + vinetaRect.height / 2;
            const translateX = viewportCenterX - currentCenterX;
            const translateY = viewportCenterY - currentCenterY;
            const ZOOM_DURATION = 0.6;
            const REDIRECT_EARLY = 0;

            isZoomed = true;

            const tl = gsap.timeline({
                onReverseComplete: () => {
                    isZoomed = false;
                    currentTl = null;
                    gsap.set(comicPage!, { clearProps: "all" });
                },
            });

            tl.to(comicPage!, {
                scale: scale,
                x: translateX,
                y: translateY,
                transformOrigin: `${originX}% ${originY}%`,
                duration: ZOOM_DURATION,
                ease: "power3.inOut",
            });

            if (targetUrl) {
                tl.call(() => {
                    isRedirecting = true;
                    navigate(targetUrl);
                }, undefined, ZOOM_DURATION - REDIRECT_EARLY-0.25);
            }

            currentTl = tl;
        }

        function zoomOut() {
            if (!isZoomed || !currentTl || isRedirecting) return;
            currentTl.reverse();
        }

        vinetas.forEach((vineta) => {
            vineta.addEventListener("click", (e) => {
                e.stopPropagation();
                const targetUrl = vineta.dataset.url;

                if (isZoomed) {
                    zoomOut();
                } else {
                    zoomToVineta(vineta, targetUrl);
                }
            });
        });

        // Click fuera del comic para salir del zoom
        document.addEventListener("click", (e) => {
            if (isZoomed && !comicPage!.contains(e.target as Node)) {
                zoomOut();
            }
        });

        // Escape para salir del zoom
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && isZoomed) {
                zoomOut();
            }
        });
    }

    // Compatible con View Transitions de Astro
    document.addEventListener("astro:page-load", initComicZoom);
</script>
