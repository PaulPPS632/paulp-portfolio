<header
	id="site-header"
	class="fixed left-1/2 top-2.5 z-30 max-w-[calc(100%-1rem)] -translate-x-1/2 rounded-full border border-black/10 bg-[rgba(245,245,245,0.95)] p-[0.35rem] shadow-[0_8px_24px_rgba(0,0,0,0.08)] backdrop-blur-md transition-[background-color,box-shadow,top,max-width] duration-300 sm:top-4 sm:max-w-none"
>
	<nav class="flex items-center gap-1" aria-label="Main navigation">
		<a
			class="js-scroll-link inline-flex items-center gap-[0.45rem] rounded-full px-[0.8rem] py-[0.52rem] font-sans text-[0.9rem] font-semibold text-[#2d2d2d] no-underline transition-colors duration-200 hover:bg-black/10 max-[820px]:px-[0.55rem] max-[820px]:py-2"
			href="/#home"
			aria-label="Ir a inicio"
		>
			<span class="js-nav-label inline-block max-w-30 overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-200">Paul</span>
			<span id="home-icon" class="inline-flex h-4 w-0 shrink-0 overflow-hidden opacity-0 transition-all duration-200" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M3 10.5L12 3L21 10.5V20C21 20.5523 20.5523 21 20 21H14V14H10V21H4C3.44772 21 3 20.5523 3 20V10.5Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</span>
		</a>

		<a
			class="js-scroll-link inline-flex items-center gap-[0.45rem] rounded-full px-[0.8rem] py-[0.52rem] font-sans text-[0.9rem] font-semibold text-[#2d2d2d] no-underline transition-colors duration-200 hover:bg-black/10 max-[820px]:px-[0.55rem] max-[820px]:py-2"
			href="/#projects"
			aria-label="Ir a proyectos"
		>
			<span class="inline-flex h-4 w-4 shrink-0" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M3 7C3 5.89543 3.89543 5 5 5H19C20.1046 5 21 5.89543 21 7V17C21 18.1046 20.1046 19 19 19H5C3.89543 19 3 18.1046 3 17V7Z" stroke="currentColor" stroke-width="1.75"/>
					<path d="M8 5V4C8 3.44772 8.44772 3 9 3H15C15.5523 3 16 3.44772 16 4V5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
				</svg>
			</span>
			<span class="js-nav-label inline-block max-w-30 overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-200">Projects</span>
		</a>

		<a
			class="js-scroll-link inline-flex items-center gap-[0.45rem] rounded-full px-[0.8rem] py-[0.52rem] font-sans text-[0.9rem] font-semibold text-[#2d2d2d] no-underline transition-colors duration-200 hover:bg-black/10 max-[820px]:px-[0.55rem] max-[820px]:py-2"
			href="/#experiencies"
			aria-label="Ir a experiencies"
		>
			<span class="inline-flex h-4 w-4 shrink-0" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 6V12L16 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="1.75"/>
				</svg>
			</span>
			<span class="js-nav-label inline-block max-w-30 overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-200">Experiencies</span>
		</a>

		<a
			class="js-scroll-link inline-flex items-center gap-[0.45rem] rounded-full px-[0.8rem] py-[0.52rem] font-sans text-[0.9rem] font-semibold text-[#2d2d2d] no-underline transition-colors duration-200 hover:bg-black/10 max-[820px]:px-[0.55rem] max-[820px]:py-2"
			href="/#skills"
			aria-label="Ir a skills"
		>
			<span class="inline-flex h-4 w-4 shrink-0" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M14 4L20 10L10 20L4 20L4 14L14 4Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
					<path d="M13 7L17 11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
				</svg>
			</span>
			<span class="js-nav-label inline-block max-w-30 overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-200">Skills</span>
		</a>

		<a
			class="js-scroll-link inline-flex items-center gap-[0.45rem] rounded-full px-[0.8rem] py-[0.52rem] font-sans text-[0.9rem] font-semibold text-[#2d2d2d] no-underline transition-colors duration-200 hover:bg-black/10 max-[820px]:px-[0.55rem] max-[820px]:py-2"
			href="/#contact"
			aria-label="Ir a contacto"
		>
			<span class="inline-flex h-4 w-4 shrink-0" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M4 6H20C20.5523 6 21 6.44772 21 7V17C21 17.5523 20.5523 18 20 18H4C3.44772 18 3 17.5523 3 17V7C3 6.44772 3.44772 6 4 6Z" stroke="currentColor" stroke-width="1.75"/>
					<path d="M3 8L12 13L21 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</span>
			<span class="js-nav-label inline-block max-w-30 overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-200">Contact</span>
		</a>
	</nav>
</header>

<script>
	const header = document.getElementById('site-header');
	const labels = document.querySelectorAll('.js-nav-label');
	const homeIcon = document.getElementById('home-icon');
	const links = document.querySelectorAll('.js-scroll-link');

	const updateHeaderState = () => {
		if (!header) return;
		const isScrolled = window.scrollY > 16;

		header.classList.toggle('bg-[rgba(245,245,245,0.95)]', !isScrolled);
		header.classList.toggle('bg-[rgba(245,245,245,0.56)]', isScrolled);
		header.classList.toggle('shadow-[0_8px_24px_rgba(0,0,0,0.08)]', !isScrolled);
		header.classList.toggle('shadow-[0_8px_24px_rgba(0,0,0,0.04)]', isScrolled);

		labels.forEach((label) => {
			label.classList.toggle('max-w-30', !isScrolled);
			label.classList.toggle('opacity-100', !isScrolled);
			label.classList.toggle('max-w-0', isScrolled);
			label.classList.toggle('opacity-0', isScrolled);
		});

		if (homeIcon) {
			homeIcon.classList.toggle('w-0', !isScrolled);
			homeIcon.classList.toggle('opacity-0', !isScrolled);
			homeIcon.classList.toggle('w-4', isScrolled);
			homeIcon.classList.toggle('opacity-100', isScrolled);
		}
	};

	updateHeaderState();
	window.addEventListener('scroll', updateHeaderState, { passive: true });

	links.forEach((link) => {
		link.addEventListener('click', (event) => {
			const anchor = event.currentTarget;
			if (!(anchor instanceof HTMLAnchorElement)) return;

			const targetId = anchor.getAttribute('href');
			if (!targetId?.startsWith('#')) return;

			const target = document.querySelector(targetId);
			if (!target) return;

			event.preventDefault();
			target.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});
	});
</script>
